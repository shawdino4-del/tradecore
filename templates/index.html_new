<!DOCTYPE html>
<html>
<head>
    <title>AI Trading Dashboard</title>

    <style>
        body {
            background: #0f172a;
            color: #e2e8f0;
            font-family: Arial;
            margin: 0;
        }

        .header {
            padding: 15px;
            background: #020617;
            text-align: center;
            font-size: 22px;
        }

        .container {
            padding: 20px;
        }

        .card {
            background: #020617;
            padding: 15px;
            border-radius: 10px;
            margin-bottom: 15px;
        }

        button {
            padding: 10px;
            margin: 5px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
        }

        .start { background: green; color: white; }
        .stop { background: red; color: white; }
        .on { background: lime; color: black; }
        .off { background: yellow; color: black; }

        #logs {
            height: 300px;
            overflow-y: scroll;
            background: black;
            padding: 10px;
            font-size: 12px;
        }
    </style>
</head>

<body>

<div class="header">
    🏦 AI Trading Dashboard
</div>

<div class="container">

    <div class="card">
        <h3>Controls</h3>

        <button class="start" onclick="startBot()">Start</button>
        <button class="stop" onclick="stopBot()">Stop</button>

        <br>

        <button class="on" onclick="enableTrading()">Enable Trading</button>
        <button class="off" onclick="disableTrading()">Disable Trading</button>
    </div>

    <div class="card">
        <h3>Status</h3>
        <div id="status">Loading...</div>
    </div>

    <div class="card">
        <h3>Logs</h3>
        <div id="logs"></div>
    </div>

</div>

<script>

function startBot() {
    fetch('/start');
}

function stopBot() {
    fetch('/stop');
}

function enableTrading() {
    fetch('/enable_trading');
}

function disableTrading() {
    fetch('/disable_trading');
}

function updateLogs() {
    fetch('/logs')
    .then(res => res.json())
    .then(data => {
        let box = document.getElementById('logs');
        box.innerHTML = data.logs.join("<br>");
        box.scrollTop = box.scrollHeight;
    });
}

function updateStatus() {
    fetch('/status')
    .then(res => res.json())
    .then(data => {
        document.getElementById('status').innerHTML =
            "Bot: " + data.bot + " | Trading: " + data.trading;
    });
}

setInterval(() => {
    updateLogs();
    updateStatus();
}, 2000);

</script>

</body>
</html>